pipeline {
    agent {
        label 'laravel'
    }

    stages {
        stage('Build') {
            steps {
                echo 'Building...'
                checkout scm

                sh 'cp .env.example .env'
                sh 'composer install --no-interaction --prefer-dist'
                sh 'npm ci'
                sh 'php artisan key:generate'
            }
        }

        stage('Test') {
            steps {
                echo 'Testing...'
                sh 'php artisan test'
            }
        }
    }

    post {
        failure {
            script {
                String token = env.TELEGRAM_BOT_TOKEN ?: ''
                String chatId = env.TELEGRAM_CHAT_ID ?: ''

                if (token && chatId) {
                    sh """
                    curl -s -X POST https://api.telegram.org/bot${token}/sendMessage \
                    -d chat_id=${chatId} \
                    -d text="🚨 Build Failed: ${env.JOB_NAME} #${env.BUILD_NUMBER}" \
                    -d parse_mode=Markdown
                    """
                } else {
                    echo "Telegram config missing"
                }
            }
        }
    }
}