pipeline {
    agent {
        label 'laravel'
    }

    stages {
        stage('Build') {
            steps {
                echo 'Building...'
                checkout scm

                sh 'test -f .env || cp .env.example .env'
                sh 'composer install --no-interaction --prefer-dist'
                sh 'npm ci'
                sh 'php artisan key:generate'
            }
        }

        stage('Test') {
            steps {
                echo 'Testing...'
                sh 'php artisan test'
            }
        }
    }

    post {
        failure {
            script {
                String token = env.TELEGRAM_BOT_TOKEN ?: ''
                String chatId = env.TELEGRAM_CHAT_ID ?: ''

                if ((!token.trim() || !chatId.trim()) && fileExists('.env')) {
                    String fileToken = sh(script: "grep -E '^TELEGRAM_BOT_TOKEN=' .env | tail -n 1 | cut -d= -f2-", returnStdout: true).trim()
                    String fileChatId = sh(script: "grep -E '^TELEGRAM_CHAT_ID=' .env | tail -n 1 | cut -d= -f2-", returnStdout: true).trim()
                    if (fileToken) {
                        token = fileToken
                    }
                    if (fileChatId) {
                        chatId = fileChatId
                    }
                }

                if (token.trim() && chatId.trim() && token != 'null' && chatId != 'null') {
                    withEnv([
                        "TG_TOKEN=${token}",
                        "TG_CHAT_ID=${chatId}",
                        "TG_JOB_NAME=${env.JOB_NAME}",
                        "TG_BUILD_NUMBER=${env.BUILD_NUMBER}",
                        "TG_BUILD_URL=${env.BUILD_URL ?: ''}",
                        "TG_BRANCH_NAME=${env.BRANCH_NAME ?: 'N/A'}",
                        "TG_RESULT=${currentBuild.currentResult ?: 'FAILURE'}"
                    ]) {
                        int rc = sh(script: '''python3 - <<'PY'
import os
import urllib.parse
import urllib.request

token = os.environ['TG_TOKEN']
chat_id = os.environ['TG_CHAT_ID']
text = "\n".join([
    "Jenkins Alert",
    "Status: FAILED",
    f"Project: {os.environ.get('TG_JOB_NAME', 'unknown')}",
    f"Build: #{os.environ.get('TG_BUILD_NUMBER', 'unknown')}",
    f"Branch: {os.environ.get('TG_BRANCH_NAME', 'N/A')}",
    f"Result: {os.environ.get('TG_RESULT', 'FAILURE')}",
    f"Details: {os.environ.get('TG_BUILD_URL', '')}",
])

url = f"https://api.telegram.org/bot{token}/sendMessage"
data = urllib.parse.urlencode({"chat_id": chat_id, "text": text}).encode()
req = urllib.request.Request(url, data=data, method="POST")
with urllib.request.urlopen(req, timeout=15) as response:
    print(response.status)
PY''', returnStatus: true)

                        if (rc != 0) {
                            echo "Telegram notification failed with status ${rc}."
                        }
                    }
                } else {
                    echo 'Telegram config missing. Set TELEGRAM_BOT_TOKEN and TELEGRAM_CHAT_ID in Jenkins Global/Job Environment Variables.'
                }
            }
        }
    }
}